# GigaChat: Base64 key for Authorization: Basic (must be base64(client_id:client_secret) from Studio)
GIGACHAT_AUTHORIZATION_KEY=

# Local dev on macOS / without НУЦ CA: set true (or 1 / yes / on). Production: use NODE_EXTRA_CA_CERTS instead.
GIGACHAT_INSECURE_TLS=true

# OAuth scope (default GIGACHAT_API_PERS). Change only if Studio issues another scope.
# GIGACHAT_OAUTH_SCOPE=GIGACHAT_API_PERS

# Optional: Client ID from Studio — same value as in Basic key; enables X-Client-ID on API calls if required.
# GIGACHAT_CLIENT_ID=

PORT=3001

# Дополнительные CORS-ориджины (через запятую). По умолчанию уже разрешены https://ads-assist-client.vercel.app и localhost для dev.
# CORS_ORIGINS=

# Лог в консоль: для каждого запроса к /api — Origin и совпадение с corsConfig (в dev всегда; в production только при true/1/yes/on).
# CORS_AUDIT_LOG=true

# Временно: ответы получают заголовки X-Debug-Cors-* и лог в консоль при блокировке Origin (см. DevTools → Network → Response Headers).
# CORS_DEBUG_HEADERS=true

# Set to production after `npm run build` to serve client/dist from Express
# NODE_ENV=production

# --- Клиент (Vite): задать в client/.env.local или в Vercel → Environment Variables при деплое только фронта ---
# Абсолютный URL API без завершающего /. Локально не указывать — используется прокси на localhost:3001.
# Не подставляйте URL вида https://vercel.com/.../project — это не API, запросы не попадут в Express.
# VITE_PUBLIC_API_BASE_URL=https://your-api.example.com

# Telegram (server-side only)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
